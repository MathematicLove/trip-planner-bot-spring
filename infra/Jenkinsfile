// infra.job - deploys Heat stack (creates VM on OpenStack)
// Requires: openstack CLI, credentials in env

pipeline {
    agent any

    options {
        buildDiscarder(logRotator(daysToKeepStr: '14', numToKeepStr: '10'))
        disableConcurrentBuilds()
    }

    parameters {
        string(name: 'STACK_NAME', defaultValue: 'tripplanner-Salimli-vm', description: 'Heat stack name')
        string(name: 'IMAGE', defaultValue: 'ubuntu-22.04', description: 'Glance image')
        string(name: 'FLAVOR', defaultValue: 'm1.small', description: 'Nova flavor')
        string(name: 'KEY_NAME', defaultValue: 'Salimli', description: 'SSH key pair name')
        string(name: 'NETWORK', defaultValue: 'students-net', description: 'Network name or ID')
    }

    stages {
        stage('Deploy Heat Stack') {
            steps {
                dir('heat') {
                    script {
                        def exists = sh(returnStatus: true, script: """
                            . /home/ubuntu/openrc.sh
                            openstack stack show ${params.STACK_NAME} >/dev/null 2>&1
                        """) == 0
                        def cmd = exists ? 'update' : 'create'
                        sh """
                            . /home/ubuntu/openrc.sh
                            openstack stack ${cmd} -t tripplanner-stack.yaml \
                              --parameter image=${params.IMAGE} \
                              --parameter flavor=${params.FLAVOR} \
                              --parameter key_name=${params.KEY_NAME} \
                              --parameter network=${params.NETWORK} \
                              ${params.STACK_NAME}
                        """
                    }
                }
            }
        }
        stage('Wait for Stack') {
            steps {
                sh """
                    . /home/ubuntu/openrc.sh
                    openstack stack show ${params.STACK_NAME} -f json
                """
                sh """
                    . /home/ubuntu/openrc.sh
                    until openstack stack show ${params.STACK_NAME} -f value -c stack_status 2>/dev/null | grep -qE 'CREATE_COMPLETE|UPDATE_COMPLETE'; do
                      sleep 10
                    done || true
                """
            }
        }
    }
    post {
        always {
            archiveArtifacts artifacts: 'heat/*.yaml', allowEmptyArchive: true
        }
    }
}
